@article{garcia-gutierrezUnveilingSoundCognitive2024,
  title = {Unveiling the Sound of the Cognitive Status: {{Machine Learning-based}} Speech Analysis in the {{Alzheimer}}'s Disease Spectrum},
  shorttitle = {Unveiling the Sound of the Cognitive Status},
  author = {{Garc{\'i}a-Guti{\'e}rrez}, Fernando and Alegret, Montserrat and Marqui{\'e}, Marta and Mu{\~n}oz, Nathalia and Ortega, Gemma and Cano, Amanda and De Rojas, Itziar and {Garc{\'i}a-Gonz{\'a}lez}, Pablo and Oliv{\'e}, Cl{\`a}udia and Puerta, Raquel and {Garc{\'i}a-Sanchez}, Ainhoa and {Capdevila-Bayo}, Mar{\'i}a and Montrreal, Laura and Pytel, Vanesa and {Rosende-Roca}, Maitee and Zaldua, Carla and Gabirondo, Peru and T{\'a}rraga, Llu{\'i}s and Ruiz, Agust{\'i}n and Boada, Merc{\`e} and Valero, Sergi},
